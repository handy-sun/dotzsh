## Find git repository root directory
git_root_dir() {
    local current_dir="$(pwd)"
    local original_dir="$current_dir"

    while [[ "$current_dir" != "/" ]]; do
        if [[ -d "$current_dir/.git" ]]; then
            echo "$current_dir"
            return 0
        fi

        current_dir="$(dirname "$current_dir")"

        # Prevent infinite loop by checking if we reached the filesystem root
        if [[ "$current_dir" = "/" ]]; then
            break
        fi
    done

    ## If we get here, we didn't find a git repo
    echo "fatal: not a git repository (or any of the parent directories): .git" >&2
    return 128
}
## Add files to git using the git root directory
gaa() {
    local root_dir=$(git_root_dir)
    if [[ $? -eq 0 ]]; then
        git -C "$root_dir" add . -v "$@"
    else
        return 1
    fi
}

groa() {
    local root_dir=$(git_root_dir)
    if [[ $? -eq 0 ]]; then
        git -C "$root_dir" restore . "$@"
    else
        return 1
    fi
}

grga() {
    local root_dir=$(git_root_dir)
    if [[ $? -eq 0 ]]; then
        git -C "$root_dir" restore --staged . "$@"
    else
        return 1
    fi
}

