alias cmkd="cmake -B\$BUILD_DIR -DCMAKE_BUILD_TYPE=Debug"
alias cmba="cmake --build \$BUILD_DIR"
alias cmbt="cmake --build \$BUILD_DIR -t"

EOF
fi

