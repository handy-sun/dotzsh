}
EOF
else
    if [ -n "$_dotzsh_is_linux" ]; then
        _dotzsh_append_buffer << 'EOF'
    if [[ "$1" =~ "/" ]]; then
        local transfer=`printf "$1" | sed 's#\/#\\\/#g'`
        ## use LC_ALL=C to avoid the file enconding diff with the terminal, which may cause the sed command not work well
        LC_ALL=C sed -i "/$transfer/d" $file
    else
        LC_ALL=C sed -i "/$1/d" $file
    fi
}
EOF
    else # darwin system
        _dotzsh_append_buffer << 'EOF'
    if [[ "$1" =~ "/" ]]; then
        local transfer=`printf "$1" | sed 's#\/#\\\/#g'`
        ## use LC_ALL=C to avoid the file enconding diff with the terminal, which may cause the sed command not work well
        LC_ALL=C sed -i "" "/$transfer/d" $file
    else
