elif _dotzsh_cmd_exists launchctl; then
    _dotzsh_append_buffer << 'EOF'
function syps -d "Search system/user services "
    if not sudo launchctl list | grep -i $argv[1]
        launchctl list | grep -i $argv[1]
    end
end

function syca -d "View plist file"
    set -l plist_path (fd "$argv[1]" /Library/Launch{Daemons,Agents} ~/Library/LaunchAgents | head -n 1)
    if test -n "$plist_path"
        echo $plist_path
        bat $plist_path
    end
end

function syst -d "launchctl load"
    set -l root_lib_path (fd "$argv[1]" /Library/Launch{Daemons,Agents} | head -n 1)
    if test -n "$root_lib_path"
        echo "sudo launchctl load "$root_lib_path
        sudo launchctl load $root_lib_path
    else
        set -l user_lib_path (fd "$argv[1]" ~/Library/LaunchAgents | head -n 1)
        if test -n "$user_lib_path"
            echo "launchctl load "$user_lib_path
            launchctl load $user_lib_path
        end
    end
end

function syte -d "launchctl unload"
    set -l root_lib_path (fd "$argv[1]" /Library/Launch{Daemons,Agents} | head -n 1)
    if test -n "$root_lib_path"
        echo "sudo launchctl unload "$root_lib_path
        sudo launchctl unload $root_lib_path
    else
        set -l user_lib_path (fd "$argv[1]" ~/Library/LaunchAgents | head -n 1)
        if test -n "$user_lib_path"
            echo "launchctl unload "$root_lib_path
            launchctl unload $user_lib_path
        end
    end
end

EOF
fi

