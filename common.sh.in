        local cur
        cur="${COMP_WORDS[COMP_CWORD]}"
        COMPREPLY=( $(compgen -W "$(_dotzsh_systemd_services)" -- "$cur") )
    }
    complete -F _dotzsh_complete_jfxeu_bash jfxeu
elif [ -n "$ZSH_VERSION" ]; then
    _dotzsh_complete_jfxeu_zsh() {
        local -a services
        services=(${(f)"$(_dotzsh_systemd_services)"})
        compadd -a services
    }
    compdef _dotzsh_complete_jfxeu_zsh jfxeu
fi

