# Search system/user services
syps() {
    if ! sudo launchctl list | grep -i "$1"; then
        launchctl list | grep -i "$1"
    fi
}
# View plist file
syca() {
    local plist_path=$(fd "$1" /Library/LaunchDaemons /Library/LaunchAgents ~/Library/LaunchAgents | head -n 1)
    if [ -n "$plist_path" ]; then
        echo $plist_path
        bat "$plist_path"
    fi
}
# launchctl load
syst() {
    local root_lib_path=$(fd "$1" /Library/LaunchDaemons /Library/LaunchAgents | head -n 1)
    if [ -n "$root_lib_path" ]; then
        echo "sudo launchctl load $root_lib_path"
        sudo launchctl load "$root_lib_path"
    else
        local user_lib_path=$(fd "$1" ~/Library/LaunchAgents | head -n 1)
        if [ -n "$user_lib_path" ]; then
            echo "launchctl load $user_lib_path"
            launchctl load "$user_lib_path"
        fi
    fi
}
# launchctl unload
syte() {
    local root_lib_path=$(fd "$1" /Library/LaunchDaemons /Library/LaunchAgents | head -n 1)
    if [ -n "$root_lib_path" ]; then
        echo "sudo launchctl unload $root_lib_path"
        sudo launchctl unload "$root_lib_path"
    else
        local user_lib_path=$(fd "$1" ~/Library/LaunchAgents | head -n 1)
        if [ -n "$user_lib_path" ]; then
            echo "launchctl unload $user_lib_path"
            launchctl unload "$user_lib_path"
        fi
    fi
}

EOF
fi

