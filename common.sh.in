qip() {
    curl -S ip-api.com/json/$1 2>/dev/null | jq '.'
}

rlip4() {
    ip -j addr | jq -r '.[] | .ifname as $name | select($name | test("^(lo|br|docker)") | not) | .addr_info[]? | select(.family=="inet") | "\(.local) \(.prefixlen) \(.label // $name)"' | column -t
}

rlip6() {
    ip -j -6 addr | jq -r '.[] | select(.ifname | test("^(lo|br|docker)") | not) | .addr_info[]? | select(.scope == "global" and ([.flags[]?] | any(. == "deprecated" or . == "tentative") | not)) | "\(.label // .local)"'
}

EOF
