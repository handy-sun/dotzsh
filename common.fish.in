EOF

if _dotzsh_cmd_exists jq; then
    _dotzsh_append_buffer << 'EOF'
function qip -d "Query IP info"
    curl -S ip-api.com/json/$argv[1] 2>/dev/null | jq '.'
end

function rlip4 -d "List local IPv4 addresses"
    ip -j addr | jq -r '.[] | .ifname as $name | select($name | test("^(lo|br|docker)") | not) | .addr_info[]? | select(.family=="inet") | "\(.local) \(.prefixlen) \(.label // $name)"' | column -t
end

function rlip6 -d "List local IPv6 addresses"
    ip -j -6 addr | jq -r '.[] | select(.ifname | test("^(lo|br|docker)") | not) | .addr_info[]? | select(.scope == "global" and ([.flags[]?] | any(. == "deprecated" or . == "tentative") | not)) | "\(.label // .local)"'
end

EOF
else
    _dotzsh_append_buffer << 'EOF'
function qip -d "Query IP info"
    curl -S ip-api.com/json/$argv[1] 2>/dev/null
end

EOF
    if [ -n "$_dotzsh_is_linux" ]; then
        _dotzsh_append_buffer << 'EOF'
function rlip4 -d "List local IPv4 addresses"
    ip -o -4 addr list | grep -Ev '\s(lo|br|docker)' | awk '{printf"%s %s\n",$4,$2}' | column -t
end
EOF
    fi
fi

_dotzsh_append_buffer << 'EOF'
function htdel -d "Delete history entries matching pattern"
    set -l file
    if set -q fish_history
        set file ~/.local/share/fish/$fish_history.history
    else if test -e ~/.local/share/fish/fish_history
        set file ~/.local/share/fish/fish_history
    else if test -e ~/.bash_history
        set file ~/.bash_history
    else
        return 1
    end

    grep -n $argv[1] $file
EOF

if _dotzsh_cmd_exists perl; then
    _dotzsh_append_buffer << 'EOF'
    perl -i -ne "print unless m{$argv[1]}" $file
end
EOF
else
    if [ -n "$_dotzsh_is_linux" ]; then
        _dotzsh_append_buffer << 'EOF'
    if string match -q '*/*' $argv[1]
        set -l transfer (printf "$argv[1]" | sed 's#\/#\\\/#g')
        LC_ALL=C sed -i "/$transfer/d" $file
    else
        LC_ALL=C sed -i "/$argv[1]/d" $file
    end
end
EOF
    else # darwin system
        _dotzsh_append_buffer << 'EOF'
    if string match -q '*/*' $argv[1]
        set -l transfer (printf "$argv[1]" | sed 's#\/#\\\/#g')
        LC_ALL=C sed -i "" "/$transfer/d" $file
    else
        LC_ALL=C sed -i "" "/$argv[1]/d" $file
    end
end
EOF
    fi
fi

if [ -n "$_dotzsh_is_linux" ] && _dotzsh_cmd_exists ldd; then
    _dotzsh_append_buffer << 'EOF'
function qlibc -d "Query GLIBC version from binary"
