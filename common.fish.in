## eza/ls [[[
if _dotzsh_cmd_exists eza; then
    eza_al='alias ls="eza --group-directories-first -A"'

    if eza --git /dev/null &>/dev/null; then
        eza_al+=$'\nalias ll="ls -blg --git"'
    else
        eza_al+=$'\nalias ll="ls -blg"'
    fi
    eza_al+=$'\nalias l="ll -B"'
    eza_al+=$'\nalias la="ll -a"'
    eza_al+=$'\nalias lr="ll -T"'
    eza_al+=$'\nalias lx="ll -sextension"'
    eza_al+=$'\nalias lk="ll -ssize"'
    eza_al+=$'\nalias lt="ll -smodified"'
    eza_al+=$'\nalias lc="ll -schanged"'

    _dotzsh_append_buffer << EOF
$eza_al

EOF
    _list_cmd='eza --group-directories-first -A -blg'
else
    if ls --color=auto /dev/null &>/dev/null; then
        _dotzsh_append_buffer << 'EOF'
if not set -q LS_OPTIONS
    set -gx LS_OPTIONS "--color=auto"
end
alias ls="ls -A \$LS_OPTIONS"
alias ll="ls -AlFh"
alias l="ls -AlF"
alias la="ls -alF"

EOF
    else
        _dotzsh_append_buffer << 'EOF'
alias ls="ls -A"
alias ll="ls -AlFh"
alias l="ls -AlF"
alias la="ls -alF"

EOF
    _list_cmd='ls -AlFh $LS_OPTIONS'
    fi
fi
## eza/ls ]]]

## package management command [[[
if _dotzsh_cmd_exists pacman; then
    if [ $(id -u) -eq 0 ]; then
        _cmd=pacman
    else
        if _dotzsh_cmd_exists yay; then
            _cmd=yay
        elif _dotzsh_cmd_exists paru; then
            _cmd=paru
        else
            _cmd=pacman
        fi
    fi
    _dotzsh_append_buffer << EOF
alias pkgsy="$_cmd -S --noconfirm"
alias pkgr="$_cmd -R"
alias pkgssq="$_cmd -Ssq"
alias pkgss="$_cmd -Ss"
alias pkgsi="$_cmd -Si"
alias pkgqs="$_cmd -Qs"
alias pkgqi="$_cmd -Qi"
alias pkgqo="$_cmd -Qo"

function pkgql -d "List package files"
    $_cmd -Ql \$argv[1] | grep -Ev '/\$' | awk '{print \$NF}' | xargs $_list_cmd
end

function pkgssw -d "Search package exact match"
    $_cmd -Ss "^\$argv[1]\\$"
end

EOF
elif _dotzsh_cmd_exists apt; then
    _cmd=apt
    _dotzsh_append_buffer << EOF
alias pkgsy="$_cmd install -y"
alias pkgr="$_cmd remove"
alias pkgss="$_cmd search"
alias pkgsi="$_cmd show"
alias pkgqi="dpkg -s"

function pkgqo -d "Query package owner"
    type -p \$argv[1] | xargs dpkg -S
end

function pkgql -d "List package files"
    dpkg -L \$argv[1] | grep -Ev '\.\$' | xargs $_list_cmd
end

function pkgqs -d "Query installed packages"
    $_cmd list --installed 2>/dev/null | grep \$argv[1]
end
EOF
elif _dotzsh_cmd_exists apk; then
    _cmd=apk
    _dotzsh_append_buffer << EOF
alias pkgsy="$_cmd add"
alias pkgr="$_cmd del"
alias pkgss="$_cmd search"
EOF
elif _dotzsh_cmd_exists brew; then
    _cmd=brew
    _dotzsh_append_buffer << EOF
alias pkgsy="$_cmd install"
alias pkgr="$_cmd uninstall"
alias pkgss="$_cmd search"
alias pkgsi="$_cmd info"
alias pkgls="$_cmd list"
alias pkgdep="$_cmd deps"
EOF
fi
## package management command ]]]


some_al=''
if _dotzsh_cmd_exists free; then
    some_al+=$'\nalias free="free -h"'
fi
if _dotzsh_cmd_exists trash; then
    some_al+=$'\nalias rm="trash"'
fi

if _dotzsh_cmd_exists xclip; then
    some_al+=$'\nalias pbcopy="xclip -selection clipboard"\nalias pbpaste="xclip -selection clipboard -o"'
fi

if _dotzsh_cmd_exists rg; then
    some_al+=$'\nalias rga="rg -i --no-ignore"'
fi

if _dotzsh_cmd_exists fzf && _dotzsh_cmd_exists bat; then
    some_al+=$'\nalias fzf="fzf --preview \'bat --color=always --style=header,grid --line-range :500 {}\'"'
fi

if _dotzsh_cmd_exists tree; then
    some_al+=$'\nalias trelh="tree -AlFh"\nalias treds="tree -hF --du --sort=size | more"'
fi

if _dotzsh_cmd_exists dust; then
    some_al+=$'\nalias dur="dust -sr"\nalias durd="dust -srb -d 1"'
fi

if _dotzsh_cmd_exists aria2c; then
    some_al+=$'\nalias ar2c="aria2c -x 8 -s 6 -j 8"'
fi

if _dotzsh_cmd_exists fd; then
    some_al+=$'\nalias fdf="fd -t f -H -I --exclude={.git,.svn,.vscode,.vs,.vscode-server,.idea,.github,node_modules,target,build,dist}"'
    some_al+=$'\nfunction fdw -d "Find by exact name"\n    fd -H -I "^$argv[1]"\'$\' $argv[2]\nend'
fi

if _dotzsh_cmd_exists unrar-free; then
    some_al+=$'\nalias unrar="unrar-free"'
fi

_dotzsh_append_buffer << EOF
$some_al
EOF

_dotzsh_append_buffer << 'EOF'
# ==========================
# 1. Colored Man Pages
# ==========================
function colored -d "Display man pages with colors"
    # Color configuration for less
    set -gx LESS_TERMCAP_mb (set_color --bold red)
    set -gx LESS_TERMCAP_md (set_color --bold red)
    set -gx LESS_TERMCAP_me (set_color normal)
    set -gx LESS_TERMCAP_so (set_color --bold yellow)
    set -gx LESS_TERMCAP_se (set_color normal)
    set -gx LESS_TERMCAP_us (set_color --bold green)
    set -gx LESS_TERMCAP_ue (set_color normal)

    # Set GROFF_NO_SGR=1 for proper color handling
    set -gx GROFF_NO_SGR 1

    # Use preferred less if available
    if command -v less &>/dev/null
        set -gx PAGER (command -v less)
    else if set -q PAGER
        # PAGER is already set
    else
        set -gx PAGER less
    end

    env $argv
end

# Override man, dman, debman functions
function man -d "Display man pages with colors"
    colored man $argv
end

function dman -d "Display dman pages with colors"
    colored dman $argv
end

function debman -d "Display debman pages with colors"
    colored debman $argv
end

# ==========================
# 2. Copy Path
# ==========================
function copypath -d "Copy file or directory path to clipboard"
    # Use current directory if no argument provided
    set -l file (test -z "$argv"; and echo "."; or echo "$argv[1]")

    # Make absolute path if relative
    if not string match -q "/*" "$file"
        set file (pwd)/"$file"
    end

    # Resolve to absolute path (without resolving symlinks)
    set file (realpath -s "$file" 2>/dev/null; or echo "$file")

    # Copy to clipboard based on available tool
    set -l copycmd
    if command -v xclip &>/dev/null
        set copycmd "xclip -selection clipboard"
    else if command -v xsel &>/dev/null
        set copycmd "xsel --clipboard --input"
    else if command -v wl-copy &>/dev/null
        set copycmd "wl-copy"
    else if command -v pbcopy &>/dev/null
        set copycmd "pbcopy"
    else if command -v clipcopy &>/dev/null
        set copycmd "clipcopy"
    else
        echo "No clipboard command found. Install xclip, xsel, wl-clipboard, or clipcopy."
        return 1
    end

    # Copy path and show message
    echo -n "$file" | eval $copycmd
    echo (set_color --bold) "$file" (set_color normal) "copied to clipboard."
end

# ==========================
# 3. Copy Buffer to Clipboard
# ==========================
function copybuffer -d "Copy active line from command line buffer to clipboard"
    # Get buffer content or last command if empty
    set -l buf (commandline)
    if test -z "$buf"
        set buf (history | head -n 1)
    end

    if test -z "$buf"
        echo "No content to copy"
        return 1
    end

    # Determine clipboard command based on OS
    set -l copycmd
    set -l os (uname -s)

    switch "$os"
    case "Linux*"
        if command -v xclip &>/dev/null
            set copycmd "xclip -selection clipboard"
        else if command -v xsel &>/dev/null
            set copycmd "xsel --clipboard --input"
        else if command -v wl-copy &>/dev/null
            set copycmd "wl-copy"
        else if command -v pbcopy &>/dev/null
            set copycmd "pbcopy"
        else
            echo "clipboard copy program not found. Install xclip, xsel, or wl-clipboard."
            return 1
        end
    case "Darwin*"
        if command -v pbcopy &>/dev/null
            set copycmd "pbcopy"
        else
            echo "clipboard copy program not found. Install pbcopy or xclip"
            return 1
        end
    case "*"
        echo "Unsupported OS: $os"
        return 1
    end

    # Copy to clipboard
    echo -n "$buf" | eval $copycmd
end

EOF

if _dotzsh_cmd_exists docker-compose; then
    _dotzsh_append_buffer << 'EOF'
# ==========================
# 4. Docker Compose Functions
# ==========================
if test -z "$DKCP_DIR"
    if test -d "/var/dkcmpo"
        set -gx DKCP_DIR /var/dkcmpo
    else
        ## DefaultDKCP_DIR if still not set
        set -gx DKCP_DIR ~/.local/share/dkcmpo
        if not test -d "$DKCP_DIR"
            mkdir -p "$DKCP_DIR"
        end
    end
end

function dcpupd -d "docker-compose up -d for specified service"
    set -l dcp_file "$DKCP_DIR/$argv[1]/docker-compose.yml"
    if test -f "$dcp_file"
        docker-compose -f "$dcp_file" up -d
    else
        echo "Error: $dcp_file not found"
        return 1
    end
end

function dcpfru -d "docker-compose up with force-recreate and remove-orphans"
    set -l dcp_file "$DKCP_DIR/$argv[1]/docker-compose.yml"
    if test -f "$dcp_file"
        docker-compose -f "$dcp_file" up -d --force-recreate --remove-orphans
    else
        echo "Error: $dcp_file not found"
        return 1
    end
end

function dcpdown -d "docker-compose down with remove-orphans"
    set -l dcp_file "$DKCP_DIR/$argv[1]/docker-compose.yml"
    if test -f "$dcp_file"
        docker-compose -f "$dcp_file" down --remove-orphans
    else
        echo "Error: $dcp_file not found"
        return 1
    end
end

function dcpte -d "docker-compose stop"
    set -l dcp_file "$DKCP_DIR/$argv[1]/docker-compose.yml"
    if test -f "$dcp_file"
        docker-compose -f "$dcp_file" stop
    else
        echo "Error: $dcp_file not found"
        return 1
    end
end

function dcprs -d "docker-compose restart"
    set -l dcp_file "$DKCP_DIR/$argv[1]/docker-compose.yml"
    if test -f "$dcp_file"
        docker-compose -f "$dcp_file" restart
    else
        echo "Error: $dcp_file not found"
        return 1
    end
end

function dcppl -d "docker-compose pull"
    set -l dcp_file "$DKCP_DIR/$argv[1]/docker-compose.yml"
    if test -f "$dcp_file"
        docker-compose -f "$dcp_file" pull
    else
        echo "Error: $dcp_file not found"
        return 1
    end
end

function dcppal -d "docker-compose pull for all services (excluding restart: no)"
    for ctner in (ls "$DKCP_DIR")
        set -l dcp_file "$DKCP_DIR/$ctner/docker-compose.yml"
        if test -f "$dcp_file"
            if not grep -iq 'restart: no' "$dcp_file"
                docker-compose -f "$dcp_file" pull
            end
        end
    end
end

function dcpca -d "cat docker-compose file with bat/cat"
    set -l dcp_file "$DKCP_DIR/$argv[1]/docker-compose.yml"
    if test -f "$dcp_file"
        if command -v bat &>/dev/null
            bat "$dcp_file"
        else
            cat "$dcp_file"
        end
    else
        echo "Error: $dcp_file not found"
        return 1
    end
end

function dcped -d "Edit docker-compose file"
    set -l dcp_file "$DKCP_DIR/$argv[1]/docker-compose.yml"
    if test -f "$dcp_file"
        if set -q EDITOR
            $EDITOR "$dcp_file"
        else
            vi "$dcp_file"
        end
    else
        echo "Error: $dcp_file not found"
        return 1
    end
end

EOF
## _dotzsh_cmd_exists docker-compose
fi

_dotzsh_append_buffer << 'EOF'
## ----------------------- fish settings ---------------------- [[[1
## Set fish colors for better prompt
set -g fish_color_normal normal
set -g fish_color_command green
set -g fish_color_keyword magenta
set -g fish_color_quote yellow
set -g fish_color_redirection cyan
set -g fish_color_end yellow
set -g fish_color_error red
set -g fish_color_param normal
set -g fish_color_comment brblack
set -g fish_color_selection white --bold --background=brblack
set -g fish_color_search_match white --background=brblack
set -g fish_color_operator cyan
set -g fish_color_escape cyan
set -g fish_color_autosuggestion brblack

set -g fish_color_user yellow
set -g fish_color_host bryellow
set -g fish_color_cwd cyan

function reverse_history_search
    history | fzf --no-sort | read -l command
    if test $command
        commandline -rb $command
    end
end

function fish_user_key_bindings
    if type -q fzf_key_bindings
        fzf_key_bindings
    end

    bind \cr reverse_history_search
    bind -M insert \cr reverse_history_search
    # Ctrl+O to copy buffer
    bind \co copybuffer

    ## Vi Insert mode: Home key - beginning of line
    bind -M insert \e\[1~ beginning-of-line 2>/dev/null
    ## Vi Insert mode: Delete key
    bind -M insert \e\[3~ delete-char 2>/dev/null
    ## Vi Insert mode: End key - end of line
    bind -M insert \e\[4~ end-of-line 2>/dev/null

    bind \e\[H beginning-of-line
    bind \e\[1~ beginning-of-line
    ## End key - end of line
    bind \e\[F end-of-line
    bind \e\[4~ end-of-line
    ## Delete key
    bind \e\[3~ delete-char
    ## Right/Left arrow keys (word navigation)
    bind \eOc forward-word
    bind \eOd backward-word
    ## PageUp/PageDown - history search
    bind \e\[5~ history-search-backward
    bind \e\[6~ history-search-forward
    ## Ctrl+Backspace - delete previous word
    bind \cH backward-kill-word
    ## Shift+Tab - undo
    bind \e\[Z undo
    ## Alt+O - cd ..
    bind \eo 'cd ..\n'
    ## Alt+; - ll
    bind \e\; 'll\n'
    ## Escape Escape - sudo command line
    # bind \e\e 'sudo '
end

alias ... 'cd ../..'
alias .... 'cd ../../..'
alias ..... 'cd ../../../..'

## ----------------------- fish settings ---------------------- ]]]1
EOF

