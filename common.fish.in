#!/usr/bin/env bash
set -e

OS_TYPE=$(uname)

if [ "$OS_TYPE" == "Linux" ]; then
    _dotzsh_is_linux=1
fi

_dotzsh_cmd_exists() {
    command -v "$@" &>/dev/null
}

real_location="$(readlink -f "$0" 2>/dev/null || readlink "$0" 2>/dev/null || echo "$0")"
current_dir=`cd $(dirname "$real_location");pwd`

if [[ $1 == "-1" ]]; then
    test ! -d ~/.cache/dotzsh/localpre && mkdir -pv ~/.cache/dotzsh/localpre
    test ! -d ~/.cache/dotzsh/localpost && mkdir -pv ~/.cache/dotzsh/localpost
    generate_file=~/.cache/dotzsh/common.fish
elif [[ $1 == "-2" ]]; then
    generate_file=/tmp/common.fish
elif [[ "$1" == "stdout" ]]; then
    generate_file=/dev/stdout
else
    full_filename=`echo ${real_location##*/}`
    strip_in_name=`echo ${full_filename%.*}`
    generate_file=${current_dir}/${strip_in_name}
fi

FISH_BUFFER=""
_dotzsh_append_buffer() {
    FISH_BUFFER+="$(cat)"$'\n\n'
}

if [[ "$generate_file" != "/dev/stdout" ]]; then
    echo "generate_file(===>fish): ${generate_file}"
fi

_dotzsh_append_buffer << 'EOF'
# -*- fish -*- #
## Do not modify this file!
## It was generated by 'common.fish.in' and may be overwritten in the future.

function cmd_exists -d "Check if a command exists"
    command -v $argv[1] &>/dev/null
end

## about git stash
function shpo -d "git stash pop by index"
    git stash pop stash@\{$argv[1]\}
end

function shap -d "git stash apply by index"
    git stash apply stash@\{$argv[1]\}
end

function shsw -d "git stash show -p by index"
    git stash show -p stash@\{$argv[1]\}
end

function shdr -d "git stash drop by index"
    git stash drop stash@\{$argv[1]\}
end

## print all info, and search insensitive
function ppre -d "Search process"
    ps -ef | grep -i "$argv[1]" | grep -vE 'grep|\]$'
end

## quickly update(rebase) git repo between local and all remotes
function gitur -d "Git update and rebase"
    # Collect files to add
    set -l files_to_add (git status -s | grep -vE '^\?\?|  ' | awk '{print $2}')
    if test -n "$files_to_add"
        git add $files_to_add
    end

    git commit
    if not git pull --rebase
        echo 'handle conflicts first!'
        return 1
    end

    set -l remote_arr (git remote)
    for var in $remote_arr
        git push $var $argv[1]
    end
end

## List all untracked files/directories in current git repo and decide whether to delete it.
function gcldi -d "Clean untracked files interactively"
    set -l untracked_files (git ls-files --directory --others)
    if test (count $untracked_files) -eq 0
        echo "No untracked files or directories found."
        return 0
    end

    echo "The following files/directories are untracked:"
    printf '\033[0;33m%s\033[0m\n' $untracked_files

    ## Ask for confirmation
    read -P "Do you want to delete all these untracked files/directories? [y/N] " answer
    switch "$answer"
    case y Y yes YES Yes
        git ls-files --directory --others | xargs rm -rf
        echo "Deletion completed."
    case '*'
        echo "Operation cancelled."
    end
end

function cdt -d "cd to file's directory or directory itself"
    if test ! -e "$argv[1]"
        echo "Error: The file or directory does not exist."
        return 1
    end
    if test -d "$argv[1]"
        cd "$argv[1]"
    else if test -f "$argv[1]"
        cd (dirname "$argv[1]")
    else
        echo "Error: Not a file or directory."
        return 1
    end
end

function upd -d "Go up N directories"
    set -l limit "$argv[1]"
    set -l dir ""
    for i in (seq 1 $limit)
        set dir "../$dir"
    end
    cd "$dir"
end

function swap2file -d "Swap two files"
    if test ! -f "$argv[1]" -o ! -f "$argv[2]"
        echo "$argv[1] or $argv[2] is not existed." >&2
        return 1
    end

    # Check if same file using inode
    set -l file1 (stat -f %i "$argv[1]" 2>/dev/null; or stat -c %i "$argv[1]" 2>/dev/null)
    set -l file2 (stat -f %i "$argv[2]" 2>/dev/null; or stat -c %i "$argv[2]" 2>/dev/null)
    if test "$file1" = "$file2"
        echo "$argv[1] and $argv[2] is same file" >&2
        return 2
    end

    set -l tempfile (mktemp ./swap2file.XXXXXXXXXX)
    mv "$argv[1]" $tempfile
    mv "$argv[2]" "$argv[1]"
    mv $tempfile "$argv[2]"
end

## about docker ---------- [[[
function dkcid -d "Get docker container ID by name"
    docker ps -qf "name= $argv[1]\$"
end

function get_docker_shell -d "Get available shell in docker container"
    set -l container "$argv[1]"
    ## Set priority list
    set -l preferred_order /bin/bash /bin/zsh /bin/sh /usr/bin/bash /usr/bin/zsh
    set -l shells (docker exec "$container" sh -c 'cat /etc/shells 2>/dev/null' 2>/dev/null)

    if test $status -eq 0 -a -n "$shells"
        set -l valid_shells (echo "$shells" | grep -E '^/' | grep -v '#')

        ## Check the first shell in order of priority list
        for shell in $preferred_order
            if echo "$valid_shells" | grep -q "^$shell\$"
                echo "$shell"
                return 0
            end
        end
    end

    ## /etc/shells not available
    docker exec "$container" sh -c '
    if command -v bash >/dev/null 2>&1; then
        echo "/bin/bash"
    elif command -v sh >/dev/null 2>&1; then
        echo "/bin/sh"
    elif command -v zsh >/dev/null 2>&1; then
        echo "/bin/zsh"
    else
        echo "unknown"
    fi
    ' 2>/dev/null
end

function dkex -d "Execute shell in docker container"
    set -l container "$argv[1]"
    set -l shell_path (get_docker_shell "$container")

    if test "$shell_path" = "unknown"
        echo "ERROR: No valid shell found in $container"
        return 1
    else
        docker exec -it "$container" "$shell_path"
    end
end
## about docker ---------- ]]]

## fwh v2.1 ---------- [[[
function _fwh_judge_built_in_or_abs_path
    set -l cmd_path (command -v -- "$argv[1]" 2>/dev/null)
    if test $status -ne 0
        echo "Error: Command '$argv[1]' not found" >&2
        return 1
    end
    if type -- "$cmd_path" 2>/dev/null | string match -q '*builtin*'
        printf "(%s:shell built-in)\n" $cmd_path
    end
end

function _fwh_resolve_alias
    set -l cmd "$argv[1]"
    ## Get alias definition in fish
    set -l alias_def (alias "$cmd" 2>/dev/null)

    if test -n "$alias_def"
        # fish alias output format: alias name 'definition'
        set -l alias_value (echo "$alias_def" | string replace -r "^alias $cmd '?''?" '' | string trim -c "'")
        set -l pointed_cmd (echo "$alias_value" | awk '{print $1}')
        ## Recursive resolve the pointed word
        if test -n "$pointed_cmd"
            echo "$alias_value"
            if test "$pointed_cmd" != "$cmd"
                _fwh_resolve_alias "$pointed_cmd"
            else
                _fwh_judge_built_in_or_abs_path "$cmd"
            end
        end
    else
        _fwh_judge_built_in_or_abs_path "$cmd"
    end
end

function _fwh_resolve_func
    set -l cmd "$argv[1]"
    if not functions -q "$cmd"
        echo "Error: Function '$cmd' not found" >&2
        return 1
    end
    ## Get definition location
    set -l src_info (type -- "$cmd" 2>/dev/null)
    echo "[Function]: $src_info"
    echo "Definition: ↴"
    functions "$cmd"
end

function _fwh_resolve_exec
    set -l cmd "$argv[1]"
    set -l initial_path (command -v -- "$cmd" 2>/dev/null)
    if test $status -ne 0
        echo "Error: Command '$cmd' not found" >&2
        return 1
    end

    if type -- "$initial_path" 2>/dev/null | string match -q '*builtin*'
        printf "(%s:shell built-in)\n" $initial_path
        return 0
    else
        printf "(%s:%s)\n" $cmd $initial_path
    end

    set -l temp_path $initial_path
    ## Follow soft link
    while test -L "$temp_path"
        set -l target (readlink "$temp_path" 2>/dev/null)
        if command -v realpath &>/dev/null
            set temp_path (realpath "$temp_path")
        else if command -v grealpath &>/dev/null
            set temp_path (grealpath "$temp_path")
        else
            # Fallback for macOS without realpath
            set temp_path (string replace -r '^[^/]' (dirname "$temp_path")/ '&' $target)
        end
        printf "  Symbolic link to: %s\n" $target
    end

    if type -- "$temp_path" 2>/dev/null | string match -q '*builtin*'
        printf "(%s:shell built-in)\n" $temp_path
        return 0
    end

    if test "$initial_path" != "$temp_path"
        printf "Final target: %s\n" "$temp_path"
    end
end

function fwh -d "Find where a command/hook/alias comes from"
    if test (count $argv) -ne 1
        echo "Usage: fwh <command>" >&2
        return 1
    end
    set -l cmd "$argv[1]"

    # Check if it's an alias
    if alias "$cmd" &>/dev/null
        echo "[Alias]"
        _fwh_resolve_alias "$cmd"
    else if functions -q "$cmd"
        _fwh_resolve_func "$cmd"
    else if cmd_exists "$cmd"
        _fwh_resolve_exec "$cmd"
    else
        echo "Error: '$cmd' is not recognized" >&2
        return 1
    end
end
## fwh ---------- }}]

