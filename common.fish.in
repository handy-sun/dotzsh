## eza/ls [[[
if _dotzsh_cmd_exists eza; then
    eza_al='alias ls="eza --group-directories-first -A"'

    if eza --git /dev/null &>/dev/null; then
        eza_al+=$'\nalias ll="ls -blg --git"'
    else
        eza_al+=$'\nalias ll="ls -blg"'
    fi
    eza_al+=$'\nalias l="ll -B"'
    eza_al+=$'\nalias la="ll -a"'
    eza_al+=$'\nalias lr="ll -T"'
    eza_al+=$'\nalias lx="ll -sextension"'
    eza_al+=$'\nalias lk="ll -ssize"'
    eza_al+=$'\nalias lt="ll -smodified"'
    eza_al+=$'\nalias lc="ll -schanged"'

    cat >> $generate_file << EOF
$eza_al

EOF
    _list_cmd='eza --group-directories-first -A -blg'
else
    if ls --color=auto /dev/null &>/dev/null; then
        cat >> $generate_file << 'EOF'
if not set -q LS_OPTIONS
    set -gx LS_OPTIONS "--color=auto"
end
alias ls="ls -A \$LS_OPTIONS"
alias ll="ls -AlFh"
alias l="ls -AlF"
alias la="ls -alF"

EOF
    else
        cat >> $generate_file << 'EOF'
alias ls="ls -A"
alias ll="ls -AlFh"
alias l="ls -AlF"
alias la="ls -alF"

EOF
    _list_cmd='ls -AlFh $LS_OPTIONS'
    fi
fi
