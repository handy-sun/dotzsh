function dus -d "Disk usage sorted"
    set -l _dir "$argv[1]"
    test -z "$_dir"; and set _dir .
    du --apparent-size -alh -d1 "$_dir" | sort -rh | head -n 21
end
'
    else
        some_al+='
function dus -d "Disk usage sorted"
    set -l _dir "$argv[1]"
    test -z "$_dir"; and set _dir .
    du -alh -d1 "$_dir" | sort -rh | head -n 21
end
'
    fi

    some_al+='
function qpid -d "Query PID by name"
    ps -eo pid,cmd | grep "$argv[1]" | grep -vE '\''grep|\]$'\'' | awk '\''{print $1}'\''
end
'

else # darwin system
    some_al+='
function dus -d "Disk usage sorted"
    set -l _dir "$argv[1]"
    test -z "$_dir"; and set _dir .
    du -Alh -d1 "$_dir" | sort -rh | head -n 21
end

function qpid -d "Query PID by name"
    /bin/ps -ef | grep "$argv[1]" | grep -vE '\''grep|\]$'\'' | awk '\''{print $2}'\''
end
'
fi

