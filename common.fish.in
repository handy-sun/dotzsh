#!env bash
set -e

OS_TYPE=$(uname)

if [ "$OS_TYPE" == "Linux" ]; then
    _dotzsh_is_linux=1
    # echo "Operating system is Linux"
# elif [ "$OS_TYPE" == "Darwin" ]; then
    # echo "Operating system is MacOS($OS_TYPE)"
# else
    # echo "Special operating system: $OS_TYPE"
fi

_dotzsh_cmd_exists() {
    command -v "$@" &>/dev/null
}

real_location="$(readlink -f "$0" 2>/dev/null || readlink "$0" 2>/dev/null || echo "$0")"
current_dir=`cd $(dirname "$real_location");pwd`

if [[ $1 -eq 1 ]]; then
    test ! -d ~/.cache/dotzsh/localpre && mkdir -pv ~/.cache/dotzsh/localpre
    test ! -d ~/.cache/dotzsh/localpost && mkdir -pv ~/.cache/dotzsh/localpost
    generate_file=~/.cache/dotzsh/common.fish
elif [[ $1 -eq 2 ]]; then
    generate_file=/tmp/common.fish
else
    full_filename=`echo ${real_location##*/}`
    strip_in_name=`echo ${full_filename%.*}`
    generate_file=${current_dir}/${strip_in_name}
fi

echo "generate_file(===>fish): ${generate_file}"

cat > $generate_file << 'EOF'
## Do not modify this file! It was generated by 'common.fish.in'
## and may be overwritten in the future.

function cmd_exists -d "Check if a command exists"
    command -v $argv[1] &>/dev/null
end

## about git stash
function shpo -d "git stash pop by index"
    git stash pop stash@{$argv[1]}
end

function shap -d "git stash apply by index"
    git stash apply stash@{$argv[1]}
end

function shsw -d "git stash show -p by index"
    git stash show -p stash@{$argv[1]}
end

function shdr -d "git stash drop by index"
    git stash drop stash@{$argv[1]}
end

## print all info, and search insensitive
function ppre -d "Search process"
    ps -ef | grep -i "$argv[1]" | grep -vE 'grep|\]$'
end

## quickly update(rebase) git repo between local and all remotes
function gitur -d "Git update and rebase"
    # Collect files to add
    set -l files_to_add (git status -s | grep -vE '^\?\?|  ' | awk '{print $2}')
    if test -n "$files_to_add"
        git add $files_to_add
    end

    git commit
    if not git pull --rebase
        echo 'handle conflicts first!'
        return 1
    end

    set -l remote_arr (git remote)
    for var in $remote_arr
        git push $var $argv[1]
    end
end

## List all untracked files/directories in current git repo and decide whether to delete it.
function gcldi -d "Clean untracked files interactively"
    set -l untracked_files (git ls-files --directory --others)
    if test (count $untracked_files) -eq 0
        echo "No untracked files or directories found."
        return 0
    end

    echo "The following files/directories are untracked:"
    printf '\033[0;33m%s\033[0m\n' $untracked_files

    ## Ask for confirmation
    printf "Do you want to delete all these untracked files/directories? [y/N] "
    read answer
    switch "$answer"
        case y Y yes YES Yes
            git ls-files --directory --others | xargs rm -rf
            echo "Deletion completed."
        case '*'
            echo "Operation cancelled."
    end
end

function cdt -d "cd to file's directory or directory itself"
    if test ! -e "$argv[1]"
        echo "Error: The file or directory does not exist."
        return 1
    end
    if test -d "$argv[1]"
        cd "$argv[1]"
    else if test -f "$argv[1]"
        cd (dirname "$argv[1]")
    else
        echo "Error: Not a file or directory."
        return 1
    end
end

function upd -d "Go up N directories"
    set -l limit "$argv[1]"
    set -l dir ""
    for i in (seq 1 $limit)
        set dir "../$dir"
    end
    cd "$dir"
end

function swap2file -d "Swap two files"
    if test ! -f "$argv[1]" -o ! -f "$argv[2]"
        echo "$argv[1] or $argv[2] is not existed." >&2
        return 1
    end

    # Check if same file using inode
    set -l file1 (stat -f %i "$argv[1]" 2>/dev/null; or stat -c %i "$argv[1]" 2>/dev/null)
    set -l file2 (stat -f %i "$argv[2]" 2>/dev/null; or stat -c %i "$argv[2]" 2>/dev/null)
    if test "$file1" = "$file2"
        echo "$argv[1] and $argv[2] is same file" >&2
        return 2
    end

    set -l tempfile (mktemp ./swap2file.XXXXXXXXXX)
    mv "$argv[1]" $tempfile
    mv "$argv[2]" "$argv[1]"
    mv $tempfile "$argv[2]"
end

## about docker ---------- [[[
function dkcid -d "Get docker container ID by name"
    docker ps -qf "name= $argv[1]\$"
end

function get_docker_shell -d "Get available shell in docker container"
    set -l container "$argv[1]"
    ## Set priority list
    set -l preferred_order /bin/bash /bin/zsh /bin/sh /usr/bin/bash /usr/bin/zsh
    set -l shells (docker exec "$container" sh -c 'cat /etc/shells 2>/dev/null' 2>/dev/null)

    if test $status -eq 0 -a -n "$shells"
        set -l valid_shells (echo "$shells" | grep -E '^/' | grep -v '#')

        ## Check the first shell in order of priority list
        for shell in $preferred_order
            if echo "$valid_shells" | grep -q "^$shell\$"
                echo "$shell"
                return 0
            end
        end
    end

    ## /etc/shells not available
    docker exec "$container" sh -c '
    if command -v bash >/dev/null 2>&1; then
        echo "/bin/bash"
    elif command -v sh >/dev/null 2>&1; then
        echo "/bin/sh"
    elif command -v zsh >/dev/null 2>&1; then
        echo "/bin/zsh"
    else
        echo "unknown"
    fi
    ' 2>/dev/null
end

function dkex -d "Execute shell in docker container"
    set -l container "$argv[1]"
    set -l shell_path (get_docker_shell "$container")

    if test "$shell_path" = "unknown"
        echo "ERROR: No valid shell found in $container"
        return 1
    else
        docker exec -it "$container" "$shell_path"
    end
end
## about docker ---------- ]]]

## fwh v2.1 ---------- [[[
function _fwh_judge_built_in_or_abs_path
    set -l cmd_path (command -v -- "$argv[1]" 2>/dev/null)
    if test $status -ne 0
        echo "Error: Command '$argv[1]' not found" >&2
        return 1
    end
    if type -- "$cmd_path" 2>/dev/null | string match -q '*builtin*'
        printf "(%s:shell built-in)\n" $cmd_path
    end
end

function _fwh_resolve_alias
    set -l cmd "$argv[1]"
    ## Get alias definition in fish
    set -l alias_def (alias "$cmd" 2>/dev/null)
    
    if test -n "$alias_def"
        # fish alias output format: alias name 'definition'
        set -l alias_value (echo "$alias_def" | string replace -r "^alias $cmd '?''?" '' | string trim -c "'")
        set -l pointed_cmd (echo "$alias_value" | awk '{print $1}')
        ## Recursive resolve the pointed word
        if test -n "$pointed_cmd"
            echo "$alias_value"
            if test "$pointed_cmd" != "$cmd"
                _fwh_resolve_alias "$pointed_cmd"
            else
                _fwh_judge_built_in_or_abs_path "$cmd"
            end
        end
    else
        _fwh_judge_built_in_or_abs_path "$cmd"
    end
end

function _fwh_resolve_func
    set -l cmd "$argv[1]"
    if not functions -q "$cmd"
        echo "Error: Function '$cmd' not found" >&2
        return 1
    end
    ## Get definition location
    set -l src_info (type -- "$cmd" 2>/dev/null)
    echo "[Function]: $src_info"
    echo "Definition: ↴"
    functions "$cmd"
end

function _fwh_resolve_exec
    set -l cmd "$argv[1]"
    set -l initial_path (command -v -- "$cmd" 2>/dev/null)
    if test $status -ne 0
        echo "Error: Command '$cmd' not found" >&2
        return 1
    end

    if type -- "$initial_path" 2>/dev/null | string match -q '*builtin*'
        printf "(%s:shell built-in)\n" $initial_path
        return 0
    else
        printf "(%s:%s)\n" $cmd $initial_path
    end
    
    set -l temp_path $initial_path
    ## Follow soft link
    while test -L "$temp_path"
        set -l target (readlink "$temp_path" 2>/dev/null)
        if command -v realpath &>/dev/null
            set temp_path (realpath "$temp_path")
        else if command -v grealpath &>/dev/null
            set temp_path (grealpath "$temp_path")
        else
            # Fallback for macOS without realpath
            set temp_path (string replace -r '^[^/]' (dirname "$temp_path")/ '&' $target)
        end
        printf "  Symbolic link to: %s\n" $target
    end

    if type -- "$temp_path" 2>/dev/null | string match -q '*builtin*'
        printf "(%s:shell built-in)\n" $temp_path
        return 0
    end

    if test "$initial_path" != "$temp_path"
        printf "Final target: %s\n" "$temp_path"
    end
end

function fwh -d "Find where a command/hook/alias comes from"
    if test (count $argv) -ne 1
        echo "Usage: fwh <command>" >&2
        return 1
    end
    set -l cmd "$argv[1]"

    # Check if it's an alias
    if alias "$cmd" &>/dev/null
        echo "[Alias]"
        _fwh_resolve_alias "$cmd"
    else if functions -q "$cmd"
        _fwh_resolve_func "$cmd"
    else if cmd_exists "$cmd"
        _fwh_resolve_exec "$cmd"
    else
        echo "Error: '$cmd' is not recognized" >&2
        return 1
    end
end
## fwh ---------- }}]

## ----------------------- alias ---------------------- [[[1
## git
alias gta="git status"
alias gts="git status -s"
alias gtun="git status uno"

alias gcm="git commit"
alias gcmm="git commit -m"
alias gcma="git commit -a"
alias gcmam="git commit -a -m"
alias gcmn="git commit --amend"
alias gcman="git commit -a --amend"

alias gpl="git pull"
alias gplrb="git pull --rebase"

alias gsh="git stash"
alias gshl="git stash list"
alias gshp="git stash pop"

alias grs="git reset"
alias grsh="git reset --hard"
alias grss="git reset --soft"
alias gro="git restore"
alias grog="git restore --staged"

alias glg="git log --pretty=format:'%Cred%h%Creset %Cgreen(%ad) %Creset%s %C(bold blue)<%an>%Creset%C(yellow)%d' --date=format:'%Y-%m-%d %H:%M' --abbrev-commit --color"
alias glp="glg --graph"
alias glh="glp | head -30"
alias glsa="git log --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --date=format:'%Y-%m-%d %H:%M' --abbrev-commit --graph --all"

alias gdf="git diff"
alias gdfh="git diff HEAD"
alias gdfc="git diff --cached"
alias gbr="git branch"
alias gba="git branch -a -v"
alias gtl="git tag --list"
alias gck="git checkout"
alias grt="git remote -v"
alias gblm="git blame -L"
alias gaprj="git apply --reject"

alias gchp="git cherry-pick"

alias gklrj="git clone --recursive --jobs 8"

alias gcln="git clean -n"
alias gclfd="git clean -fd"

## git push all remotes
function gpar -d "Push to all remotes"
    git remote | xargs -I{} git push {} $argv[1]
end

## tar
alias tarx="tar --no-same-owner -xf"
alias tarz="tar zcf"
alias tarj="tar jcf"
alias tarsc1="tar --no-same-owner --strip-components=1 -xf"
alias matarz="COPYFILE_DISABLE=1 tar --exclude='.DS_Store' -zcf"
alias maunz="ditto -V -x -k --sequesterRsrc"

## other shell utilities
alias pingk="ping -c4"
alias cp="cp -Rvf"
alias sln="ln -sfnv"
alias less="less -R"
alias rrm="rm -rf"
# alias grep="grep --color=auto"
alias diff="diff --color=auto"
alias pipins="pip install -i https://pypi.tuna.tsinghua.edu.cn/simple"
alias surl="curl --proto '=https' --tlsv1.2 -LSv"
alias dklg="docker logs -n 300 -f"

function surs -d "Secure URL check"
    curl --proto '=https' --tlsv1.2 -LSv https://$argv[1]
end
## ----------------------- alias ---------------------- ]]]

EOF

if _dotzsh_cmd_exists jq; then
    cat >> $generate_file << 'EOF'
function qip -d "Query IP info"
    curl -S ip-api.com/json/$argv[1] 2>/dev/null | jq '.'
end

function rlip4 -d "List local IPv4 addresses"
    ip -j addr | jq -r '.[] | select(.ifname | test("^lo|^br|^docker|^tun|^utun") | not) | select(.addr_info != null) | .addr_info[] | select(.family=="inet")'
end

function rlip6 -d "List local IPv6 addresses"
    ip -j addr | jq -r '.[] | select(.ifname | test("^lo|^br|^docker|^tun|^utun") | not) | select(.addr_info != null) | .addr_info[] | select(.family=="inet6" and (.local | startswith("fe80:") | not)) | .local'
end

EOF
else
    cat >> $generate_file << 'EOF'
function qip -d "Query IP info"
    curl -S ip-api.com/json/$argv[1] 2>/dev/null
end

EOF
    if [ -n "$_dotzsh_is_linux" ]; then
        cat >> $generate_file << 'EOF'
function rlip4 -d "List local IPv4 addresses"
    ip -o -4 addr list | grep -Ev '\s(docker|lo|tun)' | awk '{printf"%-20s %s\n",$2,$4}'
end
EOF
    fi
fi

cat >> $generate_file << 'EOF'
function htdel -d "Delete history entries matching pattern"
    set -l file
    if set -q fish_history
        set file ~/.local/share/fish/$fish_history.history
    else if test -e ~/.local/share/fish/fish_history
        set file ~/.local/share/fish/fish_history
    else if test -e ~/.bash_history
        set file ~/.bash_history
    else
        return 1
    end

    grep -n $argv[1] $file
EOF

if _dotzsh_cmd_exists perl; then
    cat >> $generate_file << 'EOF'
    perl -i -ne "print unless m{$argv[1]}" $file
end
EOF
else
    if [ -n "$_dotzsh_is_linux" ]; then
        cat >> $generate_file << 'EOF'
    if string match -q '*/*' $argv[1]
        set -l transfer (printf "$argv[1]" | sed 's#\/#\\\/#g')
        LC_ALL=C sed -i "/$transfer/d" $file
    else
        LC_ALL=C sed -i "/$argv[1]/d" $file
    end
end
EOF
    else # darwin system
        cat >> $generate_file << 'EOF'
    if string match -q '*/*' $argv[1]
        set -l transfer (printf "$argv[1]" | sed 's#\/#\\\/#g')
        LC_ALL=C sed -i "" "/$transfer/d" $file
    else
        LC_ALL=C sed -i "" "/$argv[1]/d" $file
    end
end
EOF
    fi
fi

if [ -n "$_dotzsh_is_linux" ] && _dotzsh_cmd_exists ldd; then
    cat >> $generate_file << 'EOF'
function qlibc -d "Query GLIBC version from binary"
    strings $argv[1] | grep -E '^GLIBC_'
end
EOF
fi

if _dotzsh_cmd_exists journalctl; then
    cat >> $generate_file << 'EOF'
function jnl -d "Journalctl follow unit"
    journalctl -eu $argv[1] | less +G
end

function jfxeu -d "Journalctl follow and tail unit"
    journalctl -n 100 -fxeu $argv[1]
end

EOF
else # macOS
    cat >> $generate_file << 'EOF'
function jnl -d "Log show for process"
    log show --predicate "process == \"$argv[1]\"" --info --last 1d
end

EOF
fi

if _dotzsh_cmd_exists pigz; then
    cat >> $generate_file << 'EOF'
## tar compress/uncompress gzip with pigz
function tcpzf -d "Tar compress with pigz"
    tar cf - $argv[2] | pigz --fast > $argv[1]
end

function txpz -d "Tar extract with pigz"
    tar --no-same-owner -xf $argv[1] -I pigz
end
EOF
fi

if _dotzsh_cmd_exists rsync; then
    cat >> $generate_file << 'EOF'
function cpv -d "Copy with rsync progress"
    rsync -pogbr -hhh --backup-dir="/tmp/rsync-$USER" -e /dev/null --progress $argv
end
EOF
fi

some_al=''
if [ -n "$_dotzsh_is_linux" ]; then
    if du --apparent-size /dev/null &>/dev/null; then
        some_al+='
function dus -d "Disk usage sorted"
    set -l _dir "$argv[1]"
    test -z "$_dir"; and set _dir .
    du --apparent-size -alh -d1 "$_dir" | sort -rh | head -n 21
end
'
    else
        some_al+='
function dus -d "Disk usage sorted"
    set -l _dir "$argv[1]"
    test -z "$_dir"; and set _dir .
    du -alh -d1 "$_dir" | sort -rh | head -n 21
end
'
    fi

    some_al+='
function qpid -d "Query PID by name"
    ps -eo pid,cmd | grep "$argv[1]" | grep -vE '\''grep|\]$'\'' | awk '\''{print $1}'\''
end
'

else # darwin system
    some_al+='
function dus -d "Disk usage sorted"
    du -Alh -d1 $argv[1] | sort -rh | head -n 21
end

function qpid -d "Query PID by name"
    ps -ef | grep "$argv[1]" | grep -vE '\''grep|\]$'\'' | awk '\''{print $2}'\''
end
'
fi

if _dotzsh_cmd_exists procs; then
    some_al+='
function rspid -d "Rapid search PID"
    procs --no-header --only PID "$argv[1]" | xargs -n 1
end
'
fi

some_al+='
function tara -d "gnutar use zstd(gnutar version >= 1.31)"
    tar cfa "$argv[1].tar.zst" "$argv[2]"
end
'

cat >> $generate_file << EOF
$some_al
EOF

if _dotzsh_cmd_exists systemctl; then
    cat >> $generate_file << 'EOF'
## systemctl
alias syta="systemctl status"
alias syca="systemctl cat"
alias syst="sudo systemctl start"
alias syrs="sudo systemctl restart"
alias syte="sudo systemctl stop"
alias syrld="sudo systemctl reload"
alias syen="sudo systemctl enable"
alias syed="sudo systemctl edit"
alias syenw="sudo systemctl enable --now"
alias sydis="sudo systemctl disable"
alias sydisw="sudo systemctl disable --now"
alias sydr="sudo systemctl daemon-reload"
alias sylss="sudo systemctl list-units -t service"
alias sylsa="sudo systemctl list-units -t service --all"

EOF
elif _dotzsh_cmd_exists launchctl; then
    cat >> $generate_file << 'EOF'
function syps -d "Search system/user services "
    if not sudo launchctl list | grep -i $argv[1]
        launchctl list | grep -i $argv[1]
    end
end

function syca -d "View plist file"
    set -l plist_path (fd "$argv[1]" /Library/Launch{Daemons,Agents} ~/Library/LaunchAgents | head -n 1)
    if test -n "$plist_path"
        echo $plist_path
        bat $plist_path
    end
end

function syst -d "launchctl load"
    set -l root_lib_path (fd "$argv[1]" /Library/Launch{Daemons,Agents} | head -n 1)
    if test -n "$root_lib_path"
        echo "sudo launchctl load "$root_lib_path
        sudo launchctl load $root_lib_path
    else
        set -l user_lib_path (fd "$argv[1]" ~/Library/LaunchAgents | head -n 1)
        if test -n "$user_lib_path"
            echo "launchctl load "$user_lib_path
            launchctl load $user_lib_path
        end
    end
end

function syte -d "launchctl unload"
    set -l root_lib_path (fd "$argv[1]" /Library/Launch{Daemons,Agents} | head -n 1)
    if test -n "$root_lib_path"
        echo "sudo launchctl unload "$root_lib_path
        sudo launchctl unload $root_lib_path
    else
        set -l user_lib_path (fd "$argv[1]" ~/Library/LaunchAgents | head -n 1)
        if test -n "$user_lib_path"
            echo "launchctl unload "$root_lib_path
            launchctl unload $user_lib_path
        end
    end
end

EOF
fi

