alias grs="git reset"
alias grsh="git reset --hard"
alias grss="git reset --soft"
alias gro="git restore"
alias grg="git restore --staged"

alias glg="git log --pretty=format:'%Cred%h%Creset %Cgreen(%ad) %Creset%s %C(bold blue)<%an>%Creset%C(yellow)%d' --date=format:'%Y-%m-%d %H:%M' --abbrev-commit --color"
alias glp="glg --graph"
alias glh="glp | head -30"
alias glsa="git log --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --date=format:'%Y-%m-%d %H:%M' --abbrev-commit --graph --all"

alias gdf="git diff"
alias gdfh="git diff HEAD"
alias gdfc="git diff --cached"
alias gbr="git branch"
alias gba="git branch -a -v"
alias gtl="git tag --list"
alias gck="git checkout"
alias gblm="git blame -L"
alias gaprj="git apply --reject"

alias gchp="git cherry-pick"

alias gklrj="git clone --recursive --jobs 8"

alias gcln="git clean -n"
alias gclfd="git clean -fd"

## git push all remotes
function gpar -d "Push to all remotes"
    git remote | xargs -I{} git push {} $argv[1]
end

function gts -d "Get dir's git status short"
    set -l d $argv[1]
    test -z "$d"; and set d .
    git -C $d status -s
end

function grt -d "Get dir's git remote verbose"
    set -l d $argv[1]
    test -z "$d"; and set d .
    git -C $d remote -v
end

function gbc -d "Create new branch and checkout to it"
    git branch $argv[1] && git checkout $argv[1]
end

function git_root_dir -d "Find and return the root directory of the current git repository"
    set -l current_dir (pwd)
    set -l original_dir $current_dir

    while test $current_dir != "/"
        if test -d "$current_dir/.git"
            echo $current_dir
            return 0
        end

        set current_dir (dirname $current_dir)

        ## Prevent infinite loop by checking if we reached the filesystem root
        if test "$current_dir" = "/"
            break
        end
    end

    ## If we get here, we didn't find a git repo
    echo "fatal: not a git repository (or any of the parent directories): .git" >&2
    return 128
end

function gaa -d "git add . -v in the git repository root directory"
    set -l root_dir (git_root_dir)
    if test $status -eq 0
        git -C "$root_dir" add . -v
    else
        return 1
    end
end

function groa -d "git restore . in the git repository root directory"
    set -l root_dir (git_root_dir)
    if test $status -eq 0
        git -C "$root_dir" restore .
    else
        return 1
    end
end

function grga -d "git restore --staged . in the git repository root directory"
    set -l root_dir (git_root_dir)
    if test $status -eq 0
        git -C "$root_dir" restore --staged .
    else
        return 1
    end
end

